# ===== Application =====
NODE_ENV=development
PORT=5000

# ===== Database =====
# NOTE: special characters in the password must be URL-encoded (& => %26)
DATABASE_URL=postgresql://r-yvan:Nry369%262008@localhost:5432/fems-db

# ===== JWT =====
JWT_SECRET=change_this_access_token_secret_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_token_secret_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ===== Password Reset =====
RESET_TOKEN_EXPIRES_MIN=30

# ===== CORS =====
CORS_ORIGIN=http://localhost:3000

# ===== Logging =====
LOG_LEVEL=info

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ===== Bcrypt =====
BCRYPT_SALT_ROUNDS=12

# ===== File exports =====
EXPORT_DIR=tmp/exports
