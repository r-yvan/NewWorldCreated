NODE_ENV=development
PORT=5006

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/fems-db

JWT_SECRET=change_this_access_token_secret_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_token_secret_in_production
JWT_REFRESH_EXPIRES_IN=7d

RESET_TOKEN_EXPIRES_MIN=30
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
BCRYPT_SALT_ROUNDS=12
EXPORT_DIR=tmp/exports
