# =====================================================
# Node.js / Next.js / React / Bun
# =====================================================
**/node_modules/
**/.next/
**/out/
**/dist/
**/build/
**/.turbo/
**/.vercel/
**/.cache/
**/.parcel-cache/

# Package manager logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/.pnpm-store/

# =====================================================
# Environment variables
# =====================================================
**/.env
**/.env.local
**/.env.development.local
**/.env.production.local
**/.env.test.local

# =====================================================
# Java / Maven / Spring Boot
# =====================================================
**/target/
**/.mvn/
**/.classpath
**/.project
**/.settings/

# IntelliJ
**/.idea/
**/*.iml

# =====================================================
# TypeScript
# =====================================================
**/*.tsbuildinfo

# =====================================================
# Python
# =====================================================
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.venv/
**/venv/

# =====================================================
# Logs
# =====================================================
**/logs/
**/*.log

# =====================================================
# Coverage / Testing
# =====================================================
**/coverage/
**/.nyc_output/

# =====================================================
# Operating System Files
# =====================================================
.DS_Store
Thumbs.db
desktop.ini

# =====================================================
# VS Code
# =====================================================
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# =====================================================
# Temporary Files
# =====================================================
**/tmp/
**/temp/
**/*.tmp
**/*.swp
**/*~

# =====================================================
# Generated Archives
# =====================================================
**/*.zip
**/*.tar.gz

# =====================================================
# Prisma
# (Keep schema, ignore generated artifacts)
# =====================================================
**/prisma/generated/

# =====================================================
# Misc
# =====================================================
**/.eslintcache
