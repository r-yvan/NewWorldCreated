{
  "expo": {
    "name": "LexiTech Dictionary",
    "slug": "lexitech-dictionary",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lexitech",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ltd.lexitech.dictionary"
    },
    "android": {
      "package": "ltd.lexitech.dictionary"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "ssr": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
